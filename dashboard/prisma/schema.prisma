generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  name          String
  role          String     @default("user")
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions PushSubscription[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Business {
  id           String            @id @default(cuid())
  name         String
  type         String
  phone        String
  city         String
  address      String?
  ownerId      String
  owner        User              @relation(fields: [ownerId], references: [id])
  services     Service[]
  employees    Employee[]
  schedules    Schedule[]
  customers    Customer[]
  appointments Appointment[]
  settings     BusinessSettings?
  subscription Subscription?
  whatsappSession WhatsappSession?
  monthlyUsage BusinessMonthlyUsage[]
  googleCalendar GoogleCalendarConnection?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

// Contador mensual por negocio (zona horaria del negocio, clave yyyy-MM).
model BusinessMonthlyUsage {
  id              String   @id @default(cuid())
  businessId      String
  periodKey       String
  aiCallCount     Int      @default(0)
  alertWarnSent   Boolean  @default(false)
  alertLimitSent  Boolean  @default(false)
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  updatedAt       DateTime @updatedAt

  @@unique([businessId, periodKey])
  @@index([periodKey])
}

model Service {
  id           String        @id @default(cuid())
  businessId   String
  name         String
  durationMin  Int
  priceHNL     Decimal       @db.Decimal(10, 2)
  isActive     Boolean       @default(true)
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model Employee {
  id            String        @id @default(cuid())
  businessId    String
  name          String
  whatsappPhone String?
  isActive      Boolean       @default(true)
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
}

model Schedule {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isOpen     Boolean  @default(true)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model Customer {
  id            String        @id @default(cuid())
  businessId    String
  whatsappPhone     String
  whatsappReplyJid  String?
  name              String?
  clientType        String?
  noShowCount   Int           @default(0)
  notes         String?
  manualTakeover Boolean      @default(false)
  takenOverAt   DateTime?
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments  Appointment[]

  @@unique([whatsappPhone, businessId])
}

model Appointment {
  id          String   @id @default(cuid())
  businessId  String
  customerId  String
  serviceId   String
  employeeId  String?
  scheduledAt DateTime
  endsAt      DateTime
  status      String   @default("pending")
  reminderSent Boolean @default(false)
  reminder1hSent Boolean @default(false)
  googleEventId String?
  googleSyncError String?
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, googleEventId])
}

model GoogleCalendarConnection {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  googleEmail        String?
  calendarId         String   @default("primary")
  calendarSummary    String?
  refreshTokenEnc    String   @db.Text
  accessTokenEnc     String?  @db.Text
  tokenExpiresAt     DateTime?
  busyCacheJson      String?  @db.Text
  busyCacheExpiresAt DateTime?
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model WhatsappMessage {
  id            String   @id @default(cuid())
  businessId    String
  customerPhone String
  body          String
  fromClient    Boolean
  createdAt     DateTime @default(now())

  @@index([businessId, customerPhone])
}

model WhatsappSession {
  id         String   @id @default(cuid())
  businessId String   @unique
  connected  Boolean  @default(false)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  updatedAt  DateTime @updatedAt
}

model BusinessSettings {
  id                String   @id @default(cuid())
  businessId        String   @unique
  bookingMode         String   @default("services")
  timezone            String   @default("America/Tegucigalpa")
  conversationTone    String   @default("casual_hn")
  welcomeMenuGreeting String?
  welcomeMenuOptions  String?  @db.Text
  websiteUrl          String?
  botPlaybooks        String?  @db.Text
  minAdvanceMinutes Int      @default(120)
  maxAdvanceDays    Int      @default(30)
  reminder24h       Boolean  @default(true)
  notifyPhone         String?
  botInstructions     String?  @db.Text
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                     String    @id @default(cuid())
  businessId             String    @unique
  plan                   String    @default("trial")
  status                 String    @default("active")
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  trialReminderSent      Boolean   @default(false)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  business               Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  updatedAt              DateTime  @updatedAt
}
