# Local (npm run dev)
PORT=3001
VPS_SECRET="mismo-secreto-que-dashboard"
DASHBOARD_URL="http://localhost:3000"
# Orígenes extra para CORS (separados por coma), ej. preview de Vercel
# CORS_ORIGINS="https://apuntado.vercel.app"
ANTHROPIC_API_KEY="[TU_ANTHROPIC_API_KEY]"
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Espera antes de responder (ms) para agrupar varios mensajes seguidos
MESSAGE_DEBOUNCE_MS="20000"
TZ=America/Tegucigalpa
AUTH_SESSIONS_DIR="./auth_sessions"

# ─── Fly.io (producción) ───
# fly secrets set VPS_SECRET="..." DASHBOARD_URL="https://apuntado.app" ANTHROPIC_API_KEY="..."
# URL pública: https://apuntado-vps.fly.dev (o tu dominio custom)
# En dashboard/.env:
#   VPS_URL="https://apuntado-vps.fly.dev"
#   NEXT_PUBLIC_VPS_URL="https://apuntado-vps.fly.dev"
